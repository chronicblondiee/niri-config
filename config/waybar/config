{
    // General Settings
    "layer": "top",
    "margin-top": 8,
    "margin-bottom": 0,
    "margin-left": 8,
    "margin-right": 8,
    "spacing": 0,
    // Load Modules
    "include": [
        "~/.config/waybar/modules.json",
        "~/.config/waybar/quicklinks.json"
    ],
    // Modules Left
    "modules-left": [
        "custom/appmenu",
        "clock",
        "group/quicklinks",
        "custom/empty"
    ],
    // Modules Center
    "modules-center": [
        "niri/workspaces",
        "custom/empty"
    ],
    // Modules Right
    "modules-right": [
        "custom/updates",
        "pulseaudio",
        "bluetooth",
        "network",
        "battery",
        "group/hardware",
        "group/tools",
        "tray",
        "custom/notification",
        "custom/exit"
    ]
}
